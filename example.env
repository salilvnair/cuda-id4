# ── Magic prompt provider (optional — only needed if you use --magic) ──────────
# Which LLM to use for auto-converting your text prompt to a structured JSON caption.
# Ideogram 4 generates much higher quality images from structured captions.
#
# Priority order (auto-detected if MAGIC_PROVIDER is blank):
#   anthropic  → ANTHROPIC_API_KEY
#   deepseek   → DEEPSEEK_API_KEY  (cheapest option, highly recommended)
#   openai     → OPENAI_API_KEY
#   ollama     → no key needed, runs locally
MAGIC_PROVIDER=deepseek
MAGIC_MODEL=

# ── LLM API keys (fill in whichever provider you chose above) ─────────────────
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=

# ── HuggingFace token (optional — only needed if the model is gated) ──────────
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=

# ── Model location override (optional) ────────────────────────────────────────
# If you saved the model to RunPod persistent storage (/workspace/...), set this.
# Leave blank to use ./models/ideogram4/ (default) or auto-download from HF.
# MODEL_PATH=/workspace/models/ideogram4
